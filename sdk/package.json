{
  "name": "@veilsub/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for VeilSub — private creator subscriptions on Aleo",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["aleo", "zk", "privacy", "subscription", "creator", "zero-knowledge"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pratiikpy/Veil-Sub"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@provablehq/sdk": ">=0.9.0"
  }
}
