NEXT_PUBLIC_PROGRAM_ID=veilsub_v27.aleo
NEXT_PUBLIC_DEPLOYED_PROGRAM_ID=veilsub_v27.aleo
NEXT_PUBLIC_ALEO_API_URL=https://api.explorer.provable.com/v1/testnet
NEXT_PUBLIC_ALEO_NETWORK=testnet
NEXT_PUBLIC_APP_URL=https://veil-sub.vercel.app

# Upstash Redis — required for persistent content storage
# Get these from https://console.upstash.com → your Redis database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase — encrypted backend for creator profiles, analytics, content
# Get these from https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Encryption key for wallet address storage (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SUPABASE_ENCRYPTION_KEY=

# Wallet auth salt — used in SHA-256(address + salt) for API authentication.
# Must match on client and server. Falls back to SUPABASE_ENCRYPTION_KEY if not set.
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
NEXT_PUBLIC_WALLET_AUTH_SALT=
