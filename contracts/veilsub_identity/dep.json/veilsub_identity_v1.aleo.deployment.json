    "edition": 0,
    "program": "program veilsub_identity_v1.aleo;\n\nrecord AuthorshipProof:\n    owner as address.private;\n    creator as address.private;\n    content_hash as field.private;\n    verified as boolean.private;\n\nmapping verified_content:\n    key as field.public;\n    value as boolean.public;\n\nmapping content_author:\n    key as field.public;\n    value as field.public;\n\nmapping identity_proofs:\n    key as field.public;\n    value as field.public;\n\nmapping content_timestamps:\n    key as field.public;\n    value as u32.public;\n\nmapping eth_identity_linked:\n    key as field.public;\n    value as boolean.public;\n\nmapping eth_to_aleo_identity:\n    key as field.public;\n    value as field.public;\n\nfunction verify_authorship:\n    input r0 as address.private;\n    input r1 as field.private;\n    input r2 as signature.private;\n    sign.verify r2 r0 r1 into r3;\n    assert.eq r3 true;\n    cast self.caller r0 r1 true into r4 as AuthorshipProof.record;\n    hash.psd2 r0 into r5 as field;\n    async verify_authorship r1 r5 into r6;\n    output r4 as AuthorshipProof.record;\n    output r6 as veilsub_identity_v1.aleo/verify_authorship.future;\n\nfinalize verify_authorship:\n    input r0 as field.public;\n    input r1 as field.public;\n    set true into verified_content[r0];\n    set r1 into content_author[r0];\n\nfunction prove_identity:\n    input r0 as field.private;\n    input r1 as signature.private;\n    sign.verify r1 self.caller r0 into r2;\n    assert.eq r2 true;\n    hash.psd2 self.caller into r3 as field;\n    hash.bhp256 r0 into r4 as field;\n    async prove_identity r3 r4 into r5;\n    output r5 as veilsub_identity_v1.aleo/prove_identity.future;\n\nfinalize prove_identity:\n    input r0 as field.public;\n    input r1 as field.public;\n    set r1 into identity_proofs[r0];\n\nfunction notarize_content:\n    input r0 as field.private;\n    input r1 as signature.private;\n    sign.verify r1 self.caller r0 into r2;\n    assert.eq r2 true;\n    hash.psd2 self.caller into r3 as field;\n    add r0 r3 into r4;\n    hash.psd2 r4 into r5 as field;\n    async notarize_content r5 into r6;\n    output r6 as veilsub_identity_v1.aleo/notarize_content.future;\n\nfinalize notarize_content:\n    input r0 as field.public;\n    get.or_use content_timestamps[r0] 0u32 into r1;\n    assert.eq r1 0u32;\n    set block.height into content_timestamps[r0];\n\nfunction verify_authorship_batch:\n    input r0 as address.private;\n    input r1 as field.private;\n    input r2 as field.private;\n    input r3 as signature.private;\n    input r4 as signature.private;\n    sign.verify r3 r0 r1 into r5;\n    assert.eq r5 true;\n    sign.verify r4 r0 r2 into r6;\n    assert.eq r6 true;\n    cast self.caller r0 r1 true into r7 as AuthorshipProof.record;\n    cast self.caller r0 r2 true into r8 as AuthorshipProof.record;\n    hash.psd2 r0 into r9 as field;\n    async verify_authorship_batch r1 r2 r9 into r10;\n    output r7 as AuthorshipProof.record;\n    output r8 as AuthorshipProof.record;\n    output r10 as veilsub_identity_v1.aleo/verify_authorship_batch.future;\n\nfinalize verify_authorship_batch:\n    input r0 as field.public;\n    input r1 as field.public;\n    input r2 as field.public;\n    set true into verified_content[r0];\n    set r2 into content_author[r0];\n    set true into verified_content[r1];\n    set r2 into content_author[r1];\n\nconstructor:\n    assert.eq edition 0u16;\n",
