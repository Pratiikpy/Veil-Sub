    "program": "program veilsub_oracle_v1.aleo;\n\nmapping price_feed:\n    key as u8.public;\n    value as u128.public;\n\nmapping price_updated_at:\n    key as u8.public;\n    value as u32.public;\n\nmapping dynamic_tier_price:\n    key as field.public;\n    value as u64.public;\n\nmapping oracle_admin:\n    key as boolean.public;\n    value as address.public;\n\nfunction initialize_oracle:\n    input r0 as address.public;\n    async initialize_oracle r0 into r1;\n    output r1 as veilsub_oracle_v1.aleo/initialize_oracle.future;\n\nfinalize initialize_oracle:\n    input r0 as address.public;\n    contains oracle_admin[true] into r1;\n    not r1 into r2;\n    assert.eq r2 true;\n    set r0 into oracle_admin[true];\n\nfunction update_price:\n    input r0 as u8.public;\n    input r1 as u128.public;\n    lte r0 2u8 into r2;\n    assert.eq r2 true;\n    gt r1 0u128 into r3;\n    assert.eq r3 true;\n    lt r1 1000000000u128 into r4;\n    assert.eq r4 true;\n    async update_price self.caller r0 r1 into r5;\n    output r5 as veilsub_oracle_v1.aleo/update_price.future;\n\nfinalize update_price:\n    input r0 as address.public;\n    input r1 as u8.public;\n    input r2 as u128.public;\n    get oracle_admin[true] into r3;\n    assert.eq r0 r3;\n    get.or_use price_feed[r1] 0u128 into r4;\n    gt r4 0u128 into r5;\n    branch.eq r5 false to end_then_0_0;\n    div r4 2u128 into r6;\n    mul r4 2u128 into r7;\n    gt r2 r6 into r8;\n    assert.eq r8 true;\n    lt r2 r7 into r9;\n    assert.eq r9 true;\n    branch.eq true true to end_otherwise_0_1;\n    position end_then_0_0;\n    position end_otherwise_0_1;\n    set r2 into price_feed[r1];\n    set block.height into price_updated_at[r1];\n\nfunction compute_tier_price:\n    input r0 as field.public;\n    input r1 as u8.public;\n    input r2 as u128.public;\n    gt r2 0u128 into r3;\n    assert.eq r3 true;\n    lte r1 20u8 into r4;\n    assert.eq r4 true;\n    async compute_tier_price r0 r1 r2 into r5;\n    output r5 as veilsub_oracle_v1.aleo/compute_tier_price.future;\n\nfinalize compute_tier_price:\n    input r0 as field.public;\n    input r1 as u8.public;\n    input r2 as u128.public;\n    get.or_use price_feed[0u8] 1000000u128 into r3;\n    mul r2 1000000u128 into r4;\n    div r4 r3 into r5;\n    cast r5 into r6 as u64;\n    cast r1 into r7 as field;\n    add r0 r7 into r8;\n    hash.psd2 r8 into r9 as field;\n    set r6 into dynamic_tier_price[r9];\n\nfunction verify_price_freshness:\n    input r0 as u8.public;\n    lte r0 2u8 into r1;\n    assert.eq r1 true;\n    async verify_price_freshness r0 into r2;\n    output r2 as veilsub_oracle_v1.aleo/verify_price_freshness.future;\n\nfinalize verify_price_freshness:\n    input r0 as u8.public;\n    get.or_use price_updated_at[r0] 0u32 into r1;\n    sub block.height r1 into r2;\n    lt r2 1000u32 into r3;\n    assert.eq r3 true;\n",
