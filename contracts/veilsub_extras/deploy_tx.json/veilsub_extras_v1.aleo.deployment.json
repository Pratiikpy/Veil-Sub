    "program": "program veilsub_extras_v1.aleo;\n\nrecord ReviewReceipt:\n    owner as address.private;\n    creator_hash as field.private;\n    rating as u8.private;\n    review_hash as field.private;\n\nrecord LotteryReceipt:\n    owner as address.private;\n    creator_hash as field.private;\n    round as u64.private;\n    round_hash as field.private;\n\nmapping review_nullifiers:\n    key as field.public;\n    value as boolean.public;\n\nmapping creator_rating_sum:\n    key as field.public;\n    value as u64.public;\n\nmapping creator_review_count:\n    key as field.public;\n    value as u64.public;\n\nmapping creator_avg_rating:\n    key as field.public;\n    value as u8.public;\n\nmapping lottery_round:\n    key as u8.public;\n    value as u64.public;\n\nmapping lottery_winner:\n    key as field.public;\n    value as u64.public;\n\nmapping lottery_entries:\n    key as field.public;\n    value as u64.public;\n\nfunction submit_review:\n    input r0 as field.private;\n    input r1 as u8.private;\n    input r2 as field.private;\n    gte r1 1u8 into r3;\n    assert.eq r3 true;\n    lte r1 5u8 into r4;\n    assert.eq r4 true;\n    hash.psd2 self.caller into r5 as field;\n    add r5 r0 into r6;\n    add r6 7777777777777777777field into r7;\n    hash.psd2 r7 into r8 as field;\n    cast self.caller r0 r1 r2 into r9 as ReviewReceipt.record;\n    async submit_review r8 r0 r1 into r10;\n    output r9 as ReviewReceipt.record;\n    output r10 as veilsub_extras_v1.aleo/submit_review.future;\n\nfinalize submit_review:\n    input r0 as field.public;\n    input r1 as field.public;\n    input r2 as u8.public;\n    get.or_use review_nullifiers[r0] false into r3;\n    not r3 into r4;\n    assert.eq r4 true;\n    set true into review_nullifiers[r0];\n    get.or_use creator_rating_sum[r1] 0u64 into r5;\n    get.or_use creator_review_count[r1] 0u64 into r6;\n    cast r2 into r7 as u64;\n    add r5 r7 into r8;\n    add r6 1u64 into r9;\n    set r8 into creator_rating_sum[r1];\n    set r9 into creator_review_count[r1];\n    div r8 r9 into r10;\n    cast r10 into r11 as u8;\n    set r11 into creator_avg_rating[r1];\n\nfunction draw_lottery:\n    input r0 as u64.private;\n    gt r0 0u64 into r1;\n    assert.eq r1 true;\n    hash.psd2 self.caller into r2 as field;\n    cast self.caller r2 0u64 r2 into r3 as LotteryReceipt.record;\n    async draw_lottery r2 r0 into r4;\n    output r3 as LotteryReceipt.record;\n    output r4 as veilsub_extras_v1.aleo/draw_lottery.future;\n\nfinalize draw_lottery:\n    input r0 as field.public;\n    input r1 as u64.public;\n    get.or_use lottery_round[0u8] 0u64 into r2;\n    add r2 1u64 into r3;\n    set r3 into lottery_round[0u8];\n    rand.chacha into r4 as u64;\n    rem r4 r1 into r5;\n    cast r3 into r6 as field;\n    add r6 r0 into r7;\n    add r7 8888888888888888888field into r8;\n    hash.psd2 r8 into r9 as field;\n    set r5 into lottery_winner[r9];\n    set r1 into lottery_entries[r9];\n",
